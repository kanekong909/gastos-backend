# Copia este archivo como .env y completa los valores
# NO subas .env a GitHub (ya está en .gitignore)

# MySQL Railway — copia estos valores desde tu proyecto Railway
DB_HOST=your_railway_host
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=gastos_db

# JWT — cambia esto por una cadena larga y aleatoria
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_seguro_2024

# Puerto del servidor
PORT=3000

# URL del frontend (para CORS) — en desarrollo usa *
FRONTEND_URL=*
